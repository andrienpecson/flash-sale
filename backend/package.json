{
  "name": "flash-sale-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Flash sale API server (Express + TypeScript)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:stress": "RATE_LIMIT_MAX=100000000 tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "gen:types": "supabase gen types typescript --project-id njcuvuehuwsnohsqxnrb --schema public > src/db/database.types.ts",
    "seed:redis": "tsx src/scripts/seedRedis.ts",
    "stress:oversell": "npm run seed:redis && tsx tests/stress/no-oversell.ts",
    "stress:user": "npm run seed:redis && tsx tests/stress/one-per-user.ts",
    "stress:clean": "tsx tests/stress/clean.ts && npm run seed:redis",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "ioredis": "^5.11.1"
  },
  "devDependencies": {
    "@types/autocannon": "^7.12.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autocannon": "^8.0.0",
    "supabase": "^2.107.0",
    "supertest": "^7.2.2",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
